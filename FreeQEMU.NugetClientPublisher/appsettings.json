{
  "NuGet": {
    // The NuGet.org API key - store this in user secrets, not here!
    // Run: dotnet user-secrets set "NuGet:ApiKey" "your-api-key-here"
    "ApiKey": "",

    // NuGet.org push endpoint
    "Source": "https://api.nuget.org/v3/index.json",

    // Package metadata (matches FreeQEMU.csproj PackageId)
    "PackageId": "FreeQEMU",
    "Version": "1.0.4",

    // Solution root directory - supports environment variables like %USERPROFILE%
    // Examples:
    //   "%USERPROFILE%\\source\\repos\\WSU-EIT\\FreeQEMU"
    //   "..\\..\\..\\..\\..\\..\\FreeQEMU"  (relative to bin folder)
    //   "" (empty = auto-detect by walking up to find .sln file)
    "SolutionRoot": "%USERPROFILE%\\source\\repos\\WSU-EIT\\FreeQEMU",

    // Path to the FreeQEMU library project (relative to SolutionRoot)
    "ProjectPath": "FreeQEMU\\FreeQEMU.csproj",

    // Build configuration
    "Configuration": "Release",

    // Skip duplicate - don't fail if version already exists
    "SkipDuplicate": true,

    // Include symbols package
    "IncludeSymbols": true
  }
}
