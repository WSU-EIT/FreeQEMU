<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <UserSecretsId>1fc89f61-31a3-4a16-84fb-55b4eb37b3a8</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FreeQEMU" Version="1.0.1" />
    <!-- QEMU binaries - needed explicitly because tools packages don't flow transitively -->
    <PackageReference Include="Mosa.Tools.Package.Qemu" Version="2.6.0.1532" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.4" />
    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" Version="9.0.4" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
